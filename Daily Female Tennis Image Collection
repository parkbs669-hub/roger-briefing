name: Daily Female Tennis Image Collection

on:
  schedule:
    # GitHub Actions의 스케줄러는 UTC 기준입니다. 
    # 한국 시간(KST) 오전 9시는 UTC 오전 0시입니다.
    - cron: '0 0 * * *'
  workflow_dispatch: # 필요할 때 수동으로도 실행할 수 있도록 설정

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.9'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install requests google-auth google-auth-oauthlib google-auth-httplib2 google-api-python-client

    - name: Run collection script
      env:
        UNSPLASH_ACCESS_KEY: ${{ secrets.UNSPLASH_ACCESS_KEY }}
        PIXABAY_API_KEY: ${{ secrets.PIXABAY_API_KEY }}
        GDRIVE_CREDENTIALS: ${{ secrets.GDRIVE_CREDENTIALS }}
        GDRIVE_FOLDER_ID: ${{ secrets.GDRIVE_FOLDER_ID }}
      run: python your_script_name.py # 실제 파이썬 파일 이름으로 수정하세요.
